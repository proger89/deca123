# SAFESORT_LAYOUT d_center_mm=8500,1200 d_size_mm=1200,800,800

WorldInfo {
  info [
    "SafeSort deterministic unknown-STL smoke world"
  ]
  basicTimeStep 32
  coordinateSystem "NUE"
}
Viewpoint {
  orientation -0.364 0.872 0.327 1.645
  position 5.35 8.65 8.95
}
DirectionalLight {
  direction -0.3 -1 -0.2
  intensity 1.2
}

DEF WORKSPACE Solid {
  translation 0 -0.05 0
  name "official_workspace_10000x6000"
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.72 0.74 0.76
        roughness 1
        metalness 0
      }
      geometry Box {
        size 10 0.1 6
      }
    }
  ]
  boundingObject Box {
    size 10 0.1 6
  }
}


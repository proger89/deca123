Robot {
  name "RuntimeController"
  controller "runtime_controller"
  children [
    RangeFinder {
      translation -3.5 2 0
      rotation 0 0 1 -1.5708
      name "rangefinder_top"
      fieldOfView 0.5
      width 96
      height 96
      minRange 0.1
      maxRange 2
      noise 0
    }
    DistanceSensor {
      translation -3.8 0.75 0
      name "photoeye_entry"
      type "laser"
      lookupTable [ 0 0 0, 0.7 0.7 0 ]
    }
    DistanceSensor {
      translation 3.3 0.75 1.1
      rotation 0 1 0 3.14159
      name "b_exit_sensor"
      type "laser"
      lookupTable [ 0 0 0, 0.7 0.7 0 ]
    }
    Emitter {
      name "runtime_events_emitter"
      channel 17
    }
    HingeJoint {
      jointParameters HingeJointParameters {
        axis 0 1 0
        anchor 0.5 0.8 0
      }
      device [
        RotationalMotor {
          name "provisional_gate_motor"
          minPosition 0
          maxPosition 1.5708
          maxVelocity 8
          maxTorque 20
          sound ""
        }
        PositionSensor {
          name "provisional_gate_position"
        }
      ]
      endPoint Solid {
        translation 0.5 0.8 0
        children [
          Shape {
            appearance PBRAppearance { baseColor 0.95 0.55 0.1 roughness 0.5 }
            geometry Box { size 0.04 0.25 0.5 }
          }
        ]
        boundingObject Box { size 0.04 0.25 0.5 }
        physics Physics { density -1 mass 1 }
      }
    }
  ]
}

Robot {
  supervisor TRUE
  name "EvaluatorSupervisor"
  controller "evaluator_supervisor"
  children [
    Receiver {
      name "runtime_events_receiver"
      channel 17
    }
  ]
}

DEF ANON_ITEM Solid {
  translation -3.5 0.73 0
  name "fixture-7f3a"
  children [
    Shape {
      appearance PBRAppearance {
        baseColor 0.85 0.1 0.08
        roughness 0.75
      }
